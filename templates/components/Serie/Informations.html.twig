{% if (serie.slug == 'les-triados') %}
    <twig:Serie:LesTriados/>
{% elseif (serie.slug == 'mamie-vitevite') %}
    <twig:Serie:MamieViteVite/>
{% elseif (serie.slug == 'la-guilde-des-seigneurs') %}
    <twig:Serie:LaGuildeDesSeigneurs/>
{% elseif (serie.slug == 'papa-calin' or serie.slug == 'papa-calin-english') %}
    <twig:Serie:PapaCalin language="{{ language }}"/>
{% endif %}