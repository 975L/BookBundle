{# for the Live Component to work, there must be a single root element (e.g. a <div>) where the attributes are applied to #}
<div {{ attributes }}>
    <input
        type="search"
        data-model="query"
        aria-label="Recherche dans les histoires"
        placeholder="Entrer les caractères recherchés"
        class="img-500"
    >

    <p class="text text-center">&nbsp;</p>
    <div class="flex-center flex-start">
        {% set books = this.books %}
        {% if books is not null and books is empty %}
            <p class="text text-center">Aucun résultat trouvé pour votre recherche.</p>
        {% elseif books is not empty %}
            <twig:Book:Books :books="books"/>
        {% endif %}
    </div>
</div>